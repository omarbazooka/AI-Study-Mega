# Supabase Project Configuration
# Replace with your actual project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key is preferred for backend ingestion bypass of Row Level Security (RLS).
# Keep this key safe and NEVER expose it to client/frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket configuration (must be created as private in Supabase Storage)
SUPABASE_STORAGE_BUCKET=study-documents

# Maximum allowed file upload size in Megabytes
MAX_UPLOAD_SIZE_MB=10

# Embedding model to load (returns 384-dimensional vectors)
# If changing this model, make sure the PG vector(dimension) column matches.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
